<!-- Lenis smooth-scroll -->
<script src="https://unpkg.com/@studio-freight/lenis@1.0.42/dist/lenis.min.js"></script>
<script>
  (function(){
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // 0. Hard-lock horizontal scroll — trackpad L/R swipes should never shift the page.
    window.addEventListener('scroll', function(){
      if(window.scrollX !== 0){ window.scrollTo(0, window.scrollY); }
    }, { passive: true });
    window.addEventListener('wheel', function(e){
      if(Math.abs(e.deltaX) > Math.abs(e.deltaY) && Math.abs(e.deltaX) > 2){
        e.preventDefault();
      }
    }, { passive: false });

    // 1. Lenis smooth scroll
    if(window.Lenis && !prefersReduced){
      var lenis = new Lenis({
        duration: 1.1,
        easing: function(t){ return Math.min(1, 1.001 - Math.pow(2, -10 * t)); },
        smoothWheel: true
      });
      function raf(time){ lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);
      window.__lenis = lenis;
    }

    // 2. Reveal-on-scroll for .tr-reveal — scroll-probe (same pattern as flip-nav;
    // IntersectionObserver is unreliable under Lenis + background-tab RAF throttle)
    var revealEls = Array.prototype.slice.call(document.querySelectorAll('.tr-reveal'));
    function syncReveal(){
      if(revealEls.length === 0) return;
      var vh = window.innerHeight;
      var remaining = [];
      for(var i=0;i<revealEls.length;i++){
        var el = revealEls[i];
        var r = el.getBoundingClientRect();
        // Fire when element's top is at least 12% into the viewport from the bottom edge.
        if(r.top < vh * 0.88 && r.bottom > 0){
          el.classList.add('is-visible');
        } else {
          remaining.push(el);
        }
      }
      revealEls = remaining;
    }
    syncReveal();
    if(window.__lenis){ window.__lenis.on('scroll', syncReveal); }
    window.addEventListener('scroll', syncReveal, { passive: true });
    window.addEventListener('resize', syncReveal);
    setInterval(syncReveal, 200);

    // 3. Flip-nav — probe on every scroll tick (Lenis + native + initial)
    var darkSections = Array.prototype.slice.call(document.querySelectorAll('[data-theme="dark"]'));
    var lastFlip = null;
    function syncFlipNav(){
      var probeY = 48;
      var over = darkSections.some(function(el){
        var r = el.getBoundingClientRect();
        return r.top <= probeY && r.bottom > probeY;
      });
      if(over !== lastFlip){
        document.body.classList.toggle('flip-nav', over);
        lastFlip = over;
      }
    }
    syncFlipNav();
    if(window.__lenis){
      window.__lenis.on('scroll', syncFlipNav);
    }
    window.addEventListener('scroll', syncFlipNav, { passive: true });
    window.addEventListener('resize', syncFlipNav);
    // Safety poll (covers throttled-RAF contexts like background tabs)
    setInterval(syncFlipNav, 200);
  })();

  /* HERO · sticky-pinned section · horizontal BG pan + phrase carousel */
  (function(){
    var stage = document.querySelector('[data-hero-stage]');
    var media = document.querySelector('.tr-hero__media');
    if(!stage || !media) return;

    function sync(){
      var r = stage.getBoundingClientRect();
      // Scroll budget = stage height minus one viewport (since hero is sticky & 100vh)
      var travel = r.height - window.innerHeight;
      var p = travel > 0 ? Math.min(Math.max(-r.top / travel, 0), 1) : 0;

      // Photo pans horizontally — starts at its left edge, scroll reveals right side
      var imgW = media.getBoundingClientRect().width;
      var maxPan = Math.max(0, imgW - window.innerWidth);
      var tx = -p * maxPan;
      media.style.transform = 'translate3d(' + tx.toFixed(1) + 'px,0,0)';
    }
    sync();
    if(window.__lenis){ window.__lenis.on('scroll', sync); }
    window.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    setInterval(sync, 200);
  })();

  /* SEC 2 · INTERACTIVE PANORAMA — scroll + drag + dot nav */
  (function(){
    var stage    = document.querySelector('[data-pan-stage]');
    var viewport = document.querySelector('[data-pan-viewport]');
    var strip    = document.querySelector('[data-pan-strip]');
    var nav      = document.querySelector('[data-pan-nav]');
    if(!stage || !viewport || !strip) return;

    var scenes = Array.prototype.slice.call(strip.querySelectorAll('[data-scene]'));
    var dots   = nav ? Array.prototype.slice.call(nav.querySelectorAll('.tr-pan-nav__dot')) : [];

    var clamp = function(v, lo, hi){ return v < lo ? lo : (v > hi ? hi : v); };
    var currentPan = 0;
    var currentP   = 0;

    function metrics(){
      var rect = stage.getBoundingClientRect();
      var vw   = window.innerWidth;
      var stripW = strip.scrollWidth;
      return {
        stageTopDoc: rect.top + window.scrollY,
        stageH: rect.height,
        travel: rect.height - window.innerHeight,
        maxPan: Math.max(0, stripW - vw),
        vw: vw
      };
    }

    function sceneCenterX(el){
      // el.offsetLeft is relative to strip; el center = offsetLeft + width/2
      return el.offsetLeft + el.offsetWidth / 2;
    }

    function applyPan(p){
      var m = metrics();
      currentP = clamp(p, 0, 1);
      currentPan = -currentP * m.maxPan;
      strip.style.transform = 'translate3d(' + currentPan.toFixed(1) + 'px,0,0)';
      updateActiveDot();
    }

    function updateActiveDot(){
      if(!scenes.length || !dots.length) return;
      var m = metrics();
      var centerX = -currentPan + m.vw / 2;
      var best = 0, bestDist = Infinity;
      for(var i = 0; i < scenes.length; i++){
        var d = Math.abs(sceneCenterX(scenes[i]) - centerX);
        if(d < bestDist){ bestDist = d; best = i; }
      }
      for(var j = 0; j < dots.length; j++){
        dots[j].classList.toggle('is-active', j === best);
      }
    }

    function syncFromScroll(){
      var rect = stage.getBoundingClientRect();
      var m = metrics();
      var p = m.travel > 0 ? clamp(-rect.top / m.travel, 0, 1) : 0;
      applyPan(p);
    }

    // Bind scroll
    syncFromScroll();
    if(window.__lenis){ window.__lenis.on('scroll', syncFromScroll); }
    window.addEventListener('scroll', syncFromScroll, { passive: true });
    window.addEventListener('resize', syncFromScroll);

    // Dot-nav — click to scrollTo the scene
    function scrollToScene(index){
      var m = metrics();
      if(m.maxPan <= 0) return;
      var target = sceneCenterX(scenes[index]) - m.vw / 2;
      target = clamp(target, 0, m.maxPan);
      var p = target / m.maxPan;
      var targetY = m.stageTopDoc + p * m.travel;
      if(window.__lenis){
        window.__lenis.scrollTo(targetY, { duration: 1.2 });
      } else {
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    }
    dots.forEach(function(dot, i){
      dot.addEventListener('click', function(){ scrollToScene(i); });
    });

    // Drag-to-pan — pointer drag maps to scroll delta so it feels like dragging the strip
    var dragging = false;
    var startX = 0;
    var startScrollY = 0;
    var pointerId = null;

    viewport.addEventListener('pointerdown', function(e){
      // Don't steal clicks on dots
      if(e.target.closest('.tr-pan-nav')) return;
      dragging = true;
      startX = e.clientX;
      startScrollY = window.scrollY;
      pointerId = e.pointerId;
      viewport.setPointerCapture(pointerId);
      viewport.classList.add('is-dragging');
    });
    viewport.addEventListener('pointermove', function(e){
      if(!dragging) return;
      var m = metrics();
      if(m.maxPan <= 0 || m.travel <= 0) return;
      var dx = e.clientX - startX;
      // Dragging right (dx>0) = reveal left content = reduce scroll
      var scrollDelta = -dx * (m.travel / m.maxPan);
      var targetY = clamp(startScrollY + scrollDelta, m.stageTopDoc, m.stageTopDoc + m.travel);
      if(window.__lenis){
        window.__lenis.scrollTo(targetY, { immediate: true });
      } else {
        window.scrollTo(0, targetY);
      }
    });
    function endDrag(){
      if(!dragging) return;
      dragging = false;
      if(pointerId !== null){
        try{ viewport.releasePointerCapture(pointerId); }catch(_){}
      }
      viewport.classList.remove('is-dragging');
    }
    viewport.addEventListener('pointerup', endDrag);
    viewport.addEventListener('pointercancel', endDrag);
    viewport.addEventListener('pointerleave', endDrag);

    // Prevent text selection flicker while dragging
    viewport.addEventListener('dragstart', function(e){ e.preventDefault(); });
  })();
</script>
