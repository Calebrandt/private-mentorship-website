<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Assistant — Private Mentorship</title>
<meta name="description" content="A consented professional placed inside every room and institution a vulnerable family member needs to navigate — with full context, returned to the family." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Archivo:wght@500;600;700;800;900&display=swap">
<style>
  :root{
    --paper:#FAFAF8;
    --paper-deep:#F2F1EC;
    --ink:#0A0A0A;
    --ink-70:rgba(10,10,10,0.70);
    --ink-55:rgba(10,10,10,0.55);
    --ink-40:rgba(10,10,10,0.40);
    --ink-15:rgba(10,10,10,0.15);
    --ink-08:rgba(10,10,10,0.08);
    --rule:rgba(10,10,10,0.12);
    --dark:#141215;
    --dark-deep:#0A0A0A;
    --paper-70:rgba(250,250,248,0.70);
    --paper-55:rgba(250,250,248,0.55);
    --paper-40:rgba(250,250,248,0.40);
    --rule-on-dark:rgba(250,250,248,0.14);
    --sans:"Inter",ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    --display:"Archivo","Inter",ui-sans-serif,system-ui,-apple-system,sans-serif;
    --ease-out:cubic-bezier(0.22, 1, 0.36, 1);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--paper);color:var(--ink);font-family:var(--sans);-webkit-font-smoothing:antialiased;}
  a{color:inherit;}

  /* Top bar */
  .tr-nav{
    position:fixed;top:0;left:0;right:0;z-index:50;
    display:flex;align-items:center;justify-content:space-between;
    padding:22px 40px;
    background:rgba(250,250,248,0.82);
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid var(--ink-08);
  }
  .tr-nav__logo{font-size:13px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--ink);text-decoration:none;}
  .tr-nav__links{display:flex;gap:28px;align-items:center;}
  .tr-nav__links a{font-size:13px;font-weight:500;letter-spacing:.02em;color:var(--ink-55);text-decoration:none;}
  .tr-nav__links a:hover{color:var(--ink);}
  .tr-nav__links a.tr-nav__cta{
    padding:10px 20px;background:var(--ink);color:var(--paper);border-radius:999px;
    font-size:13px;font-weight:600;letter-spacing:.02em;text-decoration:none;
  }
  .tr-nav__links a.tr-nav__cta:hover{color:var(--paper);}

  /* Shared layout */
  .tr-wrap{max-width:1120px;margin:0 auto;padding:0 32px;}
  .tr-narrow{max-width:760px;margin:0 auto;padding:0 32px;}

  /* ── HERO (STICKY PIN · HORIZONTAL BG PAN · PHRASE CAROUSEL) ── */
  .tr-hero-stage{
    position:relative;
    height:300vh;           /* 3 "slides" of scroll budget */
    background:#000;
  }
  .tr-hero-stage .tr-hero{
    position:sticky;
    top:0;
    height:100vh;
    min-height:640px;
    overflow:hidden;
    background:var(--paper);
  }
  .tr-hero__bg{
    position:absolute;inset:0;overflow:hidden;z-index:0;
    padding-top:80px;
    display:flex;
    align-items:center;
    justify-content:flex-start;
    box-sizing:border-box;
  }
  .tr-hero__media{
    position:relative;
    flex-shrink:0;
    display:block;
    height:auto;
    width:auto;
    max-width:none;
    max-height:100%;
    will-change:transform;
    transform:translate3d(0,0,0);
  }

  /* Horizontal sliding phrase carousel — each phrase owns its own 100vw×100vh panel */
  .tr-hero__titles{
    position:absolute;inset:0;
    overflow:hidden;
    z-index:2;
    pointer-events:none;
  }
  .tr-hero__titles-track{
    position:absolute;
    top:0;left:0;
    height:100%;
    width:max-content;
    display:flex;
    align-items:stretch;
    will-change:transform;
    transform:translate3d(0,0,0);
  }
  .tr-hero__title{
    position:relative;
    width:100vw;
    height:100vh;
    flex-shrink:0;
    margin:0;
    padding:0;
  }
  .tr-hero__title > span{
    position:absolute;
    display:block;
    font-family:"Inter",ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    font-size:clamp(40px,5.6vw,92px);
    font-weight:700;
    letter-spacing:-0.03em;
    line-height:0.98;
    text-transform:uppercase;
    color:var(--paper);
    max-width:80vw;
    /* All three phrases sit in the same upper-left block — NRG-style:
       text stays in one place while the background slides behind it. */
    left:12vw;
    top:34vh;
    text-align:left;
  }

  /* Fixed chrome (chips, cue, tagline) stays put while phrases slide */
  .tr-hero__chrome{
    position:absolute;inset:0;z-index:3;
    padding:110px 48px 52px;
    display:flex;flex-direction:column;justify-content:space-between;
    pointer-events:none;
    color:var(--paper);
  }
  .tr-hero__chrome > *{pointer-events:auto;}
  .tr-hero__chrome-top{display:flex;align-items:flex-start;}
  .tr-hero__chrome-bottom{
    display:flex;align-items:flex-end;justify-content:space-between;gap:40px;
  }
  .tr-hero__chips{
    position:absolute;
    left:12vw;
    top:27vh;
    z-index:3;
    display:inline-flex;
    gap:8px;
    flex-wrap:wrap;
    pointer-events:auto;
  }
  .tr-hero__chip{
    display:inline-block;
    background:rgba(250,250,248,0.10);
    border:1px solid rgba(250,250,248,0.18);
    color:var(--paper);
    font-family:var(--sans);
    font-size:10.5px;font-weight:600;
    letter-spacing:.28em;text-transform:uppercase;
    padding:8px 16px;
    border-radius:999px;
    backdrop-filter:blur(10px);
    -webkit-backdrop-filter:blur(10px);
  }
  .tr-hero__cue{
    font-family:var(--sans);
    font-size:11px;font-weight:600;letter-spacing:.32em;text-transform:uppercase;
    color:var(--paper-70);
    display:inline-flex;align-items:center;gap:10px;
  }
  .tr-hero__cue::after{
    content:"";width:1px;height:28px;background:var(--paper-40);
    display:inline-block;animation:tr-cue 1.8s ease-in-out infinite;
  }
  @keyframes tr-cue{
    0%,100%{transform:translateY(0);opacity:.4;}
    50%{transform:translateY(6px);opacity:.9;}
  }
  .tr-hero__tagline{
    position:absolute;
    right:8vw;
    top:62vh;
    z-index:3;
    display:flex;gap:14px;align-items:flex-start;
    max-width:320px;
    color:var(--paper);
    pointer-events:auto;
  }
  .tr-hero__tagline .tr-plus{color:var(--paper);margin-top:6px;}
  .tr-hero__tagline p{
    margin:0;
    font-family:var(--sans);
    font-size:15.5px;font-weight:500;line-height:1.45;
    color:var(--paper);
    letter-spacing:-0.005em;
  }

  @media (max-width: 780px){
    .tr-hero-stage{height:260vh;}
    .tr-hero{min-height:560px;}
    .tr-hero__chrome{padding:100px 22px 34px;}
    .tr-hero__chrome-bottom{flex-direction:column;align-items:flex-start;gap:20px;}
    .tr-hero__tagline{max-width:none;}
    .tr-hero__title > span{font-size:clamp(40px,12vw,76px);max-width:88vw;}
    .tr-hero__title--low-left  > span{bottom:18vh;}
    .tr-hero__title--high-right > span{top:20vh;}
    .tr-hero__title--low-right > span{bottom:20vh;}
  }

  /* On-page index (mini TOC) */
  .tr-toc{
    max-width:1040px;margin:72px auto 0;padding:36px 32px 64px;
    display:grid;grid-template-columns:200px 1fr;gap:48px;
    border-top:1px solid var(--rule);
  }
  .tr-toc__label{
    font-family:var(--sans);
    font-size:10.5px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;
    color:var(--ink-55);
    margin:0;padding-top:4px;
  }
  .tr-toc__list{
    list-style:none;margin:0;padding:0;
    display:grid;grid-template-columns:repeat(2,1fr);gap:2px 40px;
  }
  .tr-toc__list li{
    border-bottom:1px solid var(--rule);
  }
  .tr-toc__list li:last-child,
  .tr-toc__list li:nth-last-child(2){border-bottom:none;}
  .tr-toc__list a{
    display:grid;grid-template-columns:28px 1fr;align-items:baseline;gap:14px;
    padding:12px 0;text-decoration:none;color:var(--ink);
    font-family:var(--sans);font-size:14px;font-weight:500;letter-spacing:-0.005em;
    transition:padding .2s ease, color .2s ease;
  }
  .tr-toc__list a:hover{padding-left:6px;color:var(--ink);}
  .tr-toc__num{
    font-family:var(--sans);font-style:italic;font-size:13px;font-weight:400;
    color:var(--ink-40);
  }

  @media (max-width: 780px){
    .tr-hero__masthead{padding:14px 20px;font-size:9px;letter-spacing:.2em;gap:12px;}
    .tr-hero__masthead span:nth-child(2){display:none;}
    .tr-hero__inner{padding:48px 24px 40px;}
    .tr-hero__headline{font-size:42px;}
    .tr-hero__media{margin-top:36px;padding:0 16px;grid-template-columns:1fr;max-width:360px;gap:10px;}
    .tr-hero__media-frame--side{display:none;}
    .tr-hero__caption{padding:12px 16px 0;flex-direction:column;gap:6px;}
    .tr-toc{grid-template-columns:1fr;gap:20px;padding:28px 24px 48px;}
    .tr-toc__list{grid-template-columns:1fr;}
  }

  /* Section primitive */
  .tr-section{padding:120px 0;border-bottom:1px solid var(--rule);}
  .tr-section:last-of-type{border-bottom:none;}
  .tr-section__label{font-size:11px;font-weight:700;letter-spacing:.3em;text-transform:uppercase;color:var(--ink-40);margin:0 0 18px;}
  .tr-section__title{font-family:var(--sans);font-size:clamp(34px,5.2vw,72px);font-weight:800;letter-spacing:-0.03em;line-height:1.02;text-transform:uppercase;margin:0 0 32px;max-width:1040px;}
  .tr-section__p{font-size:17px;line-height:1.75;color:var(--ink-70);margin:0 0 22px;max-width:720px;}
  .tr-section__p strong{color:var(--ink);font-weight:600;}

  /* Figure */
  .tr-figure{margin:44px 0;border-radius:14px;overflow:hidden;border:1px solid var(--ink-08);background:#E9E0CF;}
  .tr-figure img{display:block;width:100%;height:auto;}
  .tr-figure__caption{font-size:12px;color:var(--ink-40);padding:14px 18px;background:#fff;border-top:1px solid var(--ink-08);letter-spacing:.02em;}

  /* Definition blocks */
  .tr-defs{display:grid;gap:0;margin:36px 0 0;border-top:1px solid var(--rule);}
  .tr-def{padding:28px 0;border-bottom:1px solid var(--rule);display:grid;grid-template-columns:220px 1fr;gap:32px;}
  .tr-def__term{font-size:14px;font-weight:700;letter-spacing:.02em;color:var(--ink);margin:0;}
  .tr-def__term-sub{display:block;font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-40);margin-top:6px;}
  .tr-def__copy{font-size:15px;line-height:1.75;color:var(--ink-55);margin:0;}
  .tr-def__copy strong{color:var(--ink);font-weight:600;}

  /* Checklist */
  .tr-check{list-style:none;padding:0;margin:24px 0 0;display:grid;gap:14px;max-width:720px;}
  .tr-check li{
    font-size:15px;line-height:1.6;color:var(--ink-55);
    padding:16px 20px;background:#fff;border:1px solid var(--ink-08);border-radius:10px;
    display:flex;gap:14px;align-items:flex-start;
  }
  .tr-check li::before{
    content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--ink);margin-top:9px;flex-shrink:0;
  }

  /* Begin CTA */
  .tr-begin{padding:140px 0 180px;text-align:center;background:var(--paper-deep);}
  .tr-begin__title{font-family:var(--sans);font-size:clamp(38px,5.6vw,80px);font-weight:800;letter-spacing:-0.03em;line-height:1;text-transform:uppercase;margin:0 0 24px;}
  .tr-begin__copy{font-size:16px;line-height:1.7;color:var(--ink-55);max-width:560px;margin:0 auto 40px;}
  .tr-begin__actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
  .tr-btn{
    display:inline-flex;align-items:center;gap:10px;padding:16px 28px;border-radius:999px;
    font-size:14px;font-weight:600;letter-spacing:.02em;text-decoration:none;transition:transform .25s ease, background .25s ease;
  }
  .tr-btn--primary{background:var(--ink);color:var(--paper);}
  .tr-btn--primary:hover{background:#000;transform:translateY(-1px);}
  .tr-btn--ghost{background:transparent;color:var(--ink);border:1px solid var(--ink);}
  .tr-btn--ghost:hover{background:var(--ink);color:var(--paper);}

  /* Footer */
  .tr-foot{padding:40px 32px;text-align:center;font-size:12px;color:var(--ink-40);letter-spacing:.02em;}

  @media (max-width: 780px){
    .tr-hero{padding:80px 0 60px;}
    .tr-section{padding:80px 0;}
    .tr-def{grid-template-columns:1fr;gap:10px;}
    .tr-nav{padding:16px 20px;}
    .tr-nav__links{gap:14px;}
    .tr-nav__links a:not(.tr-nav__cta){display:none;}
  }

  /* ── FOUNDATION ── */
  /* Scroll reveal primitive */
  .tr-reveal{opacity:0;transform:translateY(28px);transition:opacity 700ms var(--ease-out),transform 700ms var(--ease-out);}
  .tr-reveal.is-visible{opacity:1;transform:none;}
  .tr-reveal[data-delay="1"]{transition-delay:80ms;}
  .tr-reveal[data-delay="2"]{transition-delay:160ms;}
  .tr-reveal[data-delay="3"]{transition-delay:240ms;}
  .tr-reveal[data-delay="4"]{transition-delay:320ms;}

  @media (prefers-reduced-motion: reduce){
    .tr-reveal{opacity:1;transform:none;transition:none;}
  }

  /* Dark-theme section primitive */
  [data-theme="dark"]{
    background:var(--dark);
    color:var(--paper);
    border-color:var(--rule-on-dark);
  }
  [data-theme="dark"] .tr-section__title,
  [data-theme="dark"] h1,
  [data-theme="dark"] h2,
  [data-theme="dark"] h3{color:var(--paper);}
  [data-theme="dark"] .tr-section__label{color:var(--paper-40);}
  [data-theme="dark"] .tr-section__p{color:var(--paper-70);}
  [data-theme="dark"] .tr-section__p strong{color:var(--paper);}

  /* Flip-nav: inverts color over dark sections */
  body.flip-nav .tr-nav{
    background:rgba(20,18,21,0.82);
    border-bottom-color:var(--rule-on-dark);
  }
  body.flip-nav .tr-nav__logo{color:var(--paper);}
  body.flip-nav .tr-nav__links a{color:var(--paper-55);}
  body.flip-nav .tr-nav__links a:hover{color:var(--paper);}
  body.flip-nav .tr-nav__links a.tr-nav__cta{background:var(--paper);color:var(--ink);}
  .tr-nav,
  .tr-nav__logo,
  .tr-nav__links a{transition:background 400ms var(--ease-out),color 400ms var(--ease-out),border-color 400ms var(--ease-out);}

  /* Shared plus-icon glyph (replaces NRG's yellow accent) */
  .tr-plus{
    display:inline-block;width:14px;height:14px;position:relative;flex-shrink:0;
  }
  .tr-plus::before,
  .tr-plus::after{
    content:"";position:absolute;background:currentColor;
  }
  .tr-plus::before{left:50%;top:0;bottom:0;width:2px;transform:translateX(-50%);}
  .tr-plus::after{top:50%;left:0;right:0;height:2px;transform:translateY(-50%);}

  /* Lock horizontal overflow globally — use a body-level clip instead of
     overflow-x:hidden on html, because that would create a scroll-containing
     block and break position:sticky on descendants (hero pin, homebase). */
  body{position:relative;}
  body::after{
    content:"";
    position:fixed;inset:0;pointer-events:none;z-index:-1;
  }
  html{overflow-x:clip;overscroll-behavior-x:none;}
  body{overflow-x:clip;overscroll-behavior-x:none;touch-action:pan-y;}

  /* ─── SEC 2 · INTERACTIVE PANORAMA (scroll + drag + dot nav) ─── */
  .tr-pan-stage{
    position:relative;
    height:500vh;
    background:#FAFAF8;
  }
  .tr-pan-pin{
    position:sticky; top:0;
    height:100vh;
    overflow:hidden;
    background:
      radial-gradient(1200px 600px at 18% 20%, rgba(244,213,180,0.55), transparent 60%),
      radial-gradient(1000px 700px at 82% 78%, rgba(190,209,181,0.45), transparent 60%),
      linear-gradient(180deg, #FAFAF8 0%, #F5EFE7 100%);
  }
  .tr-pan-nav{
    position:absolute; left:28px; top:50%;
    transform:translateY(-50%);
    z-index:10;
    display:flex; flex-direction:column; gap:16px;
    padding:0; margin:0;
  }
  .tr-pan-nav__dot{
    position:relative;
    width:10px; height:10px; border-radius:50%;
    background:rgba(10,10,10,0.22);
    border:none; padding:0; cursor:pointer;
    transition:background 220ms var(--ease-out), transform 220ms var(--ease-out);
  }
  .tr-pan-nav__dot:hover{ background:rgba(10,10,10,0.55); }
  .tr-pan-nav__dot.is-active{ background:#0A0A0A; transform:scale(1.4); }
  .tr-pan-nav__dot::after{
    content:attr(data-label);
    position:absolute; left:22px; top:50%; transform:translateY(-50%);
    font-size:10px; letter-spacing:.18em; text-transform:uppercase;
    white-space:nowrap; color:var(--ink-70);
    background:rgba(250,250,248,0.88); backdrop-filter:blur(8px);
    padding:5px 10px; border-radius:999px;
    opacity:0; pointer-events:none;
    transition:opacity 180ms var(--ease-out), transform 180ms var(--ease-out);
  }
  .tr-pan-nav__dot:hover::after{ opacity:1; transform:translateY(-50%) translateX(2px); }

  .tr-pan-viewport{
    position:absolute; inset:0;
    overflow:hidden;
    cursor:grab;
    touch-action:pan-y;
  }
  .tr-pan-viewport.is-dragging{ cursor:grabbing; }

  .tr-pan-strip{
    position:absolute; top:0; left:0;
    height:100%;
    display:flex;
    align-items:center;
    padding:90px 10vw 40px;
    gap:7vw;
    width:max-content;
    will-change:transform;
    transform:translate3d(0,0,0);
  }

  .tr-pan-scene{
    flex-shrink:0;
    display:flex; flex-direction:column;
    gap:28px;
    position:relative;
  }
  .tr-pan-scene__eyebrow{
    font-size:11px; letter-spacing:.22em; text-transform:uppercase;
    color:var(--ink-55); margin:0;
    font-weight:600;
  }
  .tr-pan-scene__title{
    font-family:var(--display);
    font-size:clamp(46px, 6.4vw, 96px);
    font-weight:800;
    line-height:0.96;
    letter-spacing:-0.025em;
    margin:0;
    color:var(--ink);
  }
  .tr-pan-scene__heading{
    font-family:var(--display);
    font-size:clamp(34px, 3.6vw, 56px);
    font-weight:800;
    line-height:1.02;
    letter-spacing:-0.02em;
    margin:0;
    color:var(--ink);
  }
  .tr-pan-scene__copy{
    font-size:17px; line-height:1.6;
    color:var(--ink-70);
    margin:0;
  }
  .tr-pan-scene__copy--sm{ font-size:15px; line-height:1.55; color:var(--ink-70); margin:0; max-width:380px; }
  .tr-pan-scene__hint{
    margin-top:18px;
    font-size:12px; letter-spacing:.14em; text-transform:uppercase;
    color:var(--ink-55);
    display:inline-flex; align-items:center; gap:10px;
  }
  .tr-pan-scene__hint::before{
    content:""; width:32px; height:1px; background:var(--ink-40);
  }

  /* Scene sizings */
  .tr-pan-scene--intro{ width:640px; justify-content:center; }
  .tr-pan-scene--card{ width:560px; }
  .tr-pan-scene--trio{ width:820px; }
  .tr-pan-scene--meet{ width:620px; }
  .tr-pan-scene--programs{ width:700px; }
  .tr-pan-scene--steps{ width:900px; }
  .tr-pan-scene--pillars{ width:820px; }

  /* Illustration card */
  .tr-pan-illo{
    position:relative;
    width:100%;
    aspect-ratio:16/10;
    background:#FFFFFF;
    border-radius:22px;
    box-shadow:0 24px 60px rgba(10,10,10,0.08), 0 2px 6px rgba(10,10,10,0.04);
    overflow:hidden;
    display:flex; align-items:center; justify-content:center;
  }
  .tr-pan-illo svg{ width:86%; height:86%; display:block; }

  /* Three Ways trio cards */
  .tr-pan-trio{
    display:grid; grid-template-columns:repeat(3, 1fr);
    gap:18px;
  }
  .tr-pan-trio__card{
    padding:26px 22px;
    border-radius:18px;
    background:#FFFFFF;
    box-shadow:0 16px 40px rgba(10,10,10,0.06), 0 2px 4px rgba(10,10,10,0.03);
    display:flex; flex-direction:column; gap:12px;
  }
  .tr-pan-trio__icon{
    width:52px; height:52px; border-radius:14px;
    display:flex; align-items:center; justify-content:center;
  }
  .tr-pan-trio__icon--edu{ background:#E7EEFB; color:#3758B0; }
  .tr-pan-trio__icon--life{ background:#FCEADE; color:#C26A3A; }
  .tr-pan-trio__icon--self{ background:#F7DDE5; color:#B23A63; }
  .tr-pan-trio__icon svg{ width:26px; height:26px; }
