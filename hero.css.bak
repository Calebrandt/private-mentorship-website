:root {
  color-scheme: light;
  --bg: #f4eee4;
  --ink: #171514;
  --contour: rgba(23, 21, 20, 0.055);
  --wire: rgba(23, 21, 20, 0.22);
}

*, *::before, *::after { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "Inter", "Segoe UI", system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

body { overflow-x: hidden; }

.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  min-height: 100dvh;
  display: grid;
  place-items: center;
  overflow: hidden;
  isolation: isolate;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  color: var(--contour);
  pointer-events: none;
}

.hero__contours {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  mix-blend-mode: multiply;
}

.portrait {
  position: relative;
  z-index: 1;
  margin: 0;
  padding: 0;
  width: 100%;
  display: grid;
  place-items: center;
}

.portrait__stage {
  position: relative;
  aspect-ratio: 2752 / 1536;
  width: min(94vw, calc(90dvh * 2752 / 1536));
  max-width: 1600px;
  user-select: none;
  -webkit-user-select: none;
}

.portrait__base,
.portrait__reveal,
.portrait__wire {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.portrait__base {
  z-index: 1;
  object-fit: cover;
  pointer-events: none;
  -webkit-user-drag: none;
  image-rendering: -webkit-optimize-contrast;
}

.portrait__reveal {
  z-index: 2;
  pointer-events: none;
  opacity: 0;
  transition: opacity 500ms ease-out;
  will-change: opacity, transform;
  filter: saturate(1.02) contrast(1.015);
}

.portrait.is-loaded .portrait__reveal { opacity: 1; }

.portrait__wire {
  z-index: 3;
  color: var(--wire);
  pointer-events: none;
  opacity: 0;
  transition: opacity 600ms ease-out 60ms;
}

.portrait.is-loaded .portrait__wire { opacity: 1; }

.wire {
  stroke-dasharray: 1;
  stroke-dashoffset: 1;
  transition: stroke-dashoffset 1700ms cubic-bezier(0.65, 0.02, 0.2, 1);
  vector-effect: non-scaling-stroke;
}

.portrait.is-loaded .wire--outer  { stroke-dashoffset: 0; transition-delay:  80ms; }
.portrait.is-loaded .wire--center { stroke-dashoffset: 0; transition-delay: 280ms; }
.portrait.is-loaded .wire--crown  { stroke-dashoffset: 0; transition-delay: 560ms; }
.portrait.is-loaded .wire--visor  { stroke-dashoffset: 0; transition-delay: 740ms; }
.portrait.is-loaded .wire--jaw    { stroke-dashoffset: 0; transition-delay: 920ms; }

@media (prefers-reduced-motion: reduce) {
  .portrait__reveal,
  .portrait__wire,
  .wire { transition-duration: 0ms; }
}
